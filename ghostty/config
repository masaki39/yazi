keybind = global:alt+space=toggle_quick_terminal
quick-terminal-position=center
quick-terminal-animation-duration=0
theme = TokyoNight
macos-option-as-alt = true
macos-titlebar-style=tabs
maximize = true
keybind = alt+right=unbind
keybind = alt+left=unbind
keybind = super+alt+right=next_tab
keybind = super+alt+left=previous_tab
keybind = super+ctrl+down=goto_split:down
keybind = super+ctrl+left=goto_split:left
keybind = super+ctrl+right=goto_split:right
keybind = super+ctrl+up=goto_split:up
keybind = super+ctrl+shift+down=resize_split:down,10
keybind = super+ctrl+shift+left=resize_split:left,10
keybind = super+ctrl+shift+right=resize_split:right,10
keybind = super+ctrl+shift+up=resize_split:up,10
