// writing.kdl
keybind "ctrl+alt+2"
description "Writing: Obsidian fullscreen"
hide_others true

window {
    app "Obsidian"
    screen 1
    x "0%"
    y "0%"
    w "100%"
    h "100%"
    reuse true
    focus true
}
window {
    app "Ghostty"
    screen 0
    x "0%"
    y "0%"
    w "100%"
    h "100%"
    reuse true
}
